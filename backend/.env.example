# ============================================================
# WatchTower — Backend Environment Variables (EXAMPLE)
# Copy this file to .env and fill in your real values.
# ============================================================

# --- OMDB API ---
# Free key (1,000 poster fetches/day): https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_key_here

# --- Supabase ---
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# --- CORS ---
# In production, set this to your frontend domain ONLY (no trailing slash)
# Example: ALLOWED_ORIGINS=https://watchtower.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Direct Postgres (Supports IPv4 connection pooler) ---
DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Server ---
# Number of gunicorn worker processes. Rule of thumb: (2 * CPU cores) + 1
# Default is 2 — increase for high-traffic deployments
WEB_CONCURRENCY=2
