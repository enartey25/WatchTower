# ============================================================
# WatchTower Backend — .dockerignore
# ============================================================

# Python artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Secrets — NEVER bake into image; pass via env_file / secrets
.env
*.env

# Generated cache — excluded from image (built up at runtime)
data/poster_cache.json

# Dev tooling
.idea/
.vscode/
*.suo
*.user

# Logs
*.log

# OS
.DS_Store
Thumbs.db
desktop.ini
