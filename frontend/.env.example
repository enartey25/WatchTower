# ============================================================
# WatchTower — Frontend Environment Variables (EXAMPLE)
# Copy this file to .env and fill in your real values.
# ============================================================

# --- API ---
# In development, leave blank — Vite proxy forwards /api → localhost:8000
# In production, set to your deployed backend URL (no trailing slash)
VITE_API_URL=

# --- Supabase (public anon key — safe to expose) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
